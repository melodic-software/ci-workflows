{
  "problemMatcher": [
    {
      "owner": "markdownlint-cli2",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^(.+?):(\\d+)(?::(\\d+))?\\s+(?:(?:error|warning)\\s+)?(MD\\d+[\\w/-]*)\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "code": 4,
          "message": 5
        }
      ]
    }
  ]
}
